{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommitTypeAll(bump)"
  ],
  "timezone": "Europe/Paris",
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "enabledManagers": [
    "ansible-galaxy",
    "argocd",
    "custom.regex",
    "dockerfile",
    "github-actions",
    "kubernetes",
    "kustomize",
    "terraform"
  ],
  "argocd": {
    "managerFilePatterns": ["/^apps/gitops/clusters/.+\\.yaml$/"]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/^apps/(argocd|bingops|cloudflare|platform|workloads)/.+\\.yaml$/",
      "/^capi/.+\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update tool versions declared in Dockerfile environment variables",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[a-z-]+))?\\s+(?:ENV|ARG) [A-Z0-9_]+=(?<currentValue>[^\\s]+)"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Keep container references reproducible",
      "matchDatasources": ["docker"],
      "pinDigests": true
    },
    {
      "description": "Group GitHub Actions maintenance",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Require manual review for infrastructure major updates",
      "matchManagers": ["argocd", "kustomize", "terraform"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ]
}
